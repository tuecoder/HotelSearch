# ── Virtual environments ─────────────────────────────────────────────────────
hotelenv/
venv/
.venv/
env/

# ── Python cache ─────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python

# ── Distribution / packaging ─────────────────────────────────────────────────
dist/
build/
*.egg-info/
*.egg

# ── Jupyter ──────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb_checkpoints

# ── Test & coverage ───────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
coverage.xml

# ── Type checkers / linters ───────────────────────────────────────────────────
.mypy_cache/
.ruff_cache/

# ── Environment variables ────────────────────────────────────────────────────
.env
.env.*
!.env.example

# ── Data — raw & processed (large files, not for version control) ────────────
data/raw/
data/processed/
# keep the folder structure
!data/raw/.gitkeep
!data/processed/.gitkeep

# ── Trained models ───────────────────────────────────────────────────────────
models/*.onnx
models/*.pkl
models/*.pt
models/*.bin
# keep the folder
!models/.gitkeep

# ── OS artefacts ─────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── IDE ───────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.suo
*.user

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
logs/

